<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/termux_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:paddingStart="8dp"
    android:paddingTop="18dp"
    android:paddingEnd="8dp"
    android:paddingBottom="4dp"
    android:visibility="gone">

    <FrameLayout
        android:id="@+id/termux_window_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="2dp"
        android:paddingStart="10dp"
        android:paddingTop="28dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/termux_output_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp">

                <ScrollView
                    android:id="@+id/termux_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="34dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/termux_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textIsSelectable="true"
                        android:textSize="13sp" />
                </ScrollView>

                <TextView
                    android:id="@+id/termux_output_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="12dp"
                    android:gravity="center"
                    android:minWidth="104dp"
                    android:paddingStart="10dp"
                    android:paddingTop="1dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="1dp"
                    android:text="OUTPUT"
                    android:textAllCaps="true"
                    android:textSize="12sp" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/termux_input_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:minHeight="42dp"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="6dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/termux_prefix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ "
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/termux_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:imeOptions="actionGo|flagNoFullscreen"
                    android:importantForAutofill="no"
                    android:singleLine="true"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/termux_tools"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:paddingEnd="0dp">

                <LinearLayout
                    android:id="@+id/termux_keys_row_one"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/termux_key_esc"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="ESC"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_slash"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="/"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/termux_key_dash"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="-"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/termux_key_home"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="HOME"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_up"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="UP"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_end"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="END"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_pgup"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="PGUP"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_setup"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="CFG"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/termux_keys_row_two"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/termux_key_tab"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="TAB"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_ctrl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="CTRL"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_alt"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="ALT"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_left"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="LEFT"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_down"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="DOWN"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_right"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="RIGHT"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_pgdn"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="PGDN"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/termux_key_ime"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="IME"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/termux_window_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:minWidth="160dp"
        android:paddingStart="12dp"
        android:paddingTop="2dp"
        android:paddingEnd="12dp"
        android:paddingBottom="2dp"
        android:text="TERMUX"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/termux_close"
        android:layout_width="48dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="X"
        android:textSize="15sp" />

</FrameLayout>
