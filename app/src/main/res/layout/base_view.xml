<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainview"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                layout="@layout/about_device_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/terminal_tray_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <include
            layout="@layout/terminal_page"
            android:layout_width="match_parent"
            android:layout_height="112dp" />

        <!-- Persistent Input Area -->
        <LinearLayout
            android:id="@+id/persistent_input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout android:id="@+id/input_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="@integer/input_group_weightsum">

                <ohi.andre.consolelauncher.tuils.OutlineTextView
                    android:id="@+id/prefix_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ohi.andre.consolelauncher.tuils.OutlineEditText
                    android:id="@+id/input_view"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="@integer/input_view_weight"

                    android:background="@null"
                    android:imeOptions="actionGo|flagNoFullscreen"
                    android:textCursorDrawable="@drawable/cursor"

                    android:importantForAutofill="no"

                    android:lines="1"
                    android:singleLine="true"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="@integer/enter_view_weight"

                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:id="@+id/submit_tv"

                        android:background="@null"
                        android:src="@drawable/ic_enter"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout android:id="@+id/tools_view"
                android:layout_width="match_parent"
                android:layout_height="@dimen/tools_height"
                android:orientation="horizontal"
                android:weightSum="@integer/tools_view_weightsum">

                <ImageButton android:id="@+id/delete_view"
                    style="@style/ToolsBar"
                    android:src="@drawable/ic_clear"/>

                <ImageButton android:id="@+id/back_view"
                    style="@style/ToolsBar"
                    android:src="@drawable/ic_back"/>

                <ImageButton android:id="@+id/next_view"
                    style="@style/ToolsBar"
                    android:src="@drawable/ic_next"/>

                <ImageButton android:id="@+id/paste_view"
                    style="@style/ToolsBar"
                    android:src="@drawable/ic_paste"/>

                <ImageButton android:id="@+id/app_drawer_view"
                    style="@style/ToolsBar"
                    android:background="@null"
                    android:src="@drawable/ic_menu"/>

            </LinearLayout>

            <HorizontalScrollView android:id="@+id/suggestions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/suggestions_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="left|center_vertical"
                        android:orientation="horizontal">

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/landscape_split_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:weightSum="2"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/landscape_left_pane"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false" />

        <View
            android:id="@+id/landscape_fold_gutter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/landscape_right_pane"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false" />

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/hack_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:padding="20dp">

        <ScrollView
            android:id="@+id/hack_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/hack_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="13sp" />

        </ScrollView>

    </RelativeLayout>

    <include
        layout="@layout/clock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        layout="@layout/termux_console"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        layout="@layout/file_console"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        layout="@layout/apps_drawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
