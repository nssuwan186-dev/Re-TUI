<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/music_widget"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingTop="6dp"
    android:paddingEnd="16dp"
    android:paddingBottom="4dp"
    android:background="@android:color/transparent"
    android:visibility="gone">

    <FrameLayout
        android:id="@+id/music_widget_border"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="104dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/terminal_border"
        android:paddingStart="6dp"
        android:paddingTop="22dp"
        android:paddingEnd="6dp"
        android:paddingBottom="8dp">

        <ohi.andre.consolelauncher.tuils.MusicVisualizerView
            android:id="@+id/music_visualizer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_gravity="bottom" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="0dp"
            android:paddingEnd="10dp"
            android:paddingBottom="0dp">

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_song_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Title: -"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ohi.andre.consolelauncher.tuils.OutlineTextView
                android:id="@+id/music_singer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Singer      : -"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/music_prev"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="PREV"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/music_play_pause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="28dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1.35"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="PLAY/PAUSE"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/music_next"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="NEXT"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/music_widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/music_widget_border"
        android:layout_alignStart="@id/music_widget_border"
        android:layout_marginTop="-10dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/apps_drawer_header_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:minWidth="170dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="NOW PLAYING"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/music_widget_close"
        android:layout_width="48dp"
        android:layout_height="34dp"
        android:layout_alignEnd="@id/music_widget_border"
        android:layout_alignTop="@id/music_widget_border"
        android:layout_marginTop="-10dp"
        android:background="@drawable/apps_drawer_header_border"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="X"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</RelativeLayout>
